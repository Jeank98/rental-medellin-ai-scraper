DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Google Cloud OAuth 2.0 credentials (for db-to-sheets export)
# Create at: https://console.cloud.google.com/auth/clients/create
# Application type: Desktop app
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# Target Google Sheet (optional — if set, updates this sheet in-place)
# Get from sheet URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
# GOOGLE_SHEET_ID=

# Target Google Drive folder (optional — new sheets are created here)
# Get from folder URL: https://drive.google.com/drive/folders/{FOLDER_ID}
# GOOGLE_SHEET_FOLDER_ID=
